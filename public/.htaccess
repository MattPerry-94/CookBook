DirectoryIndex index.php
RewriteEngine On
RewriteRule ^assets/flaticon\.svg$ assets/flaticon.png [R=302,L,NC]
RewriteCond %{REQUEST_METHOD} =POST
RewriteRule ^CookBook/(.*)$ /$1 [QSA,L,NC]
RewriteCond %{REQUEST_METHOD} !=POST
RewriteRule ^CookBook/?$ / [QSA,R=301,L,NC]
RewriteCond %{REQUEST_METHOD} !=POST
RewriteRule ^CookBook/(.*)$ /$1 [QSA,R=301,L,NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CookBook - Recettes</title>
    <link rel="stylesheet" href="/public/css/style.css?v=4">
</head>
<body>
<header>
    <div>
        <strong>CookBook</strong>
    </div>
    <nav>
        <a href="/">Accueil</a>
        {% if currentUser %}
            <a href="/my-recipes">Mes recettes</a>
            <a href="/messages">
                Messages
                {% if unreadMessagesCount > 0 %}
                    <span class="badge" style="background: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.8rem; vertical-align: top;">{{ unreadMessagesCount|escape }}</span>
                {% endif %}
            </a>
            <a href="/recipes/create">Créer une recette</a>
            {% if isAdmin %}
                <a href="/admin">Administration</a>
            {% endif %}
            <a href="/logout">Déconnexion</a>
            <span class="user-badge">{{ currentUser|escape }}</span>
        {% else %}
            <a href="/signin">Connexion</a>
            <a href="/signup">Inscription</a>
        {% endif %}
    </nav>
</header>
<main>
    <h1>Les dernières recettes</h1>

    <form method="get" class="search-bar">
        <input type="text" name="q" placeholder="Rechercher par titre ou ingrédient" value="{{ query|default('')|escape }}">
        <button type="submit">Rechercher</button>
    </form>

    {% if recipes is defined and recipes|length > 0 %}
        <div class="recipes-grid">
            {% for recipe in recipes %}
                <a class="card card-link" href="/recipes/{{ recipe.id }}">
                    {% if recipe.image_path %}
                        <img src="{{ recipe.image_path|escape }}" alt="Photo de {{ recipe.title|escape }}">
                    {% endif %}
                    <div class="card-body">
                        <h2 class="card-title">{{ recipe.title|escape }}</h2>
                        <div class="card-meta">
                            {% if recipe.category_name %}
                                <span>{{ recipe.category_name|escape }} • </span>
                            {% endif %}
                            {% if recipe.author_name %}
                                <span>par {{ recipe.author_name|escape }}</span>
                            {% endif %}
                        </div>
                        <p>{{ recipe.description|default('')|slice(0, 120)|escape }}{% if recipe.description and recipe.description|length > 120 %}...{% endif %}</p>
                        
                        {% if recipe.comments|length > 0 %}
                            <div class="comments-preview" style="margin-top: 1rem; padding-top: 0.5rem; border-top: 1px solid #eee; font-size: 0.9em;">
                                <strong>Derniers commentaires :</strong>
                                <ul style="list-style: none; padding: 0; margin: 0.5rem 0 0;">
                                    {% for comment in recipe.comments|slice(0, 2) %}
                                        <li style="margin-bottom: 0.5rem;">
                                            <span style="font-weight: bold; color: #666;">{{ comment.author_name|escape }}:</span>
                                            {{ comment.content|slice(0, 50)|escape }}{% if comment.content|length > 50 %}...{% endif %}
                                        </li>
                                    {% endfor %}
                                    {% if recipe.comments|length > 2 %}
                                        <li><em style="color: #888;">+ {{ (recipe.comments|length - 2)|escape }} autres commentaires</em></li>
                                    {% endif %}
                                </ul>
                            </div>
                        {% endif %}

                        <span class="card-cta">Voir la recette</span>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty">
            Aucune recette pour le moment. Soyez le premier à en créer une !
        </div>
    {% endif %}
</main>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

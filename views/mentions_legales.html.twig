<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mentions légales - CookBook</title>
    <link rel="stylesheet" href="{{ basePath }}/public/css/style.css?v=6">
    <link rel="icon" href="{{ basePath }}/public/assets/flaticon.png" type="image/png">
</head>
<body>
<header>
    <div>
        <strong><a class="site-brand-link" href="{{ basePath }}/" style="color: inherit; text-decoration: none;">CookBook</a></strong>
    </div>
    <nav>
        <a href="{{ basePath }}/">Accueil</a>
        {% if currentUser %}
            <a href="{{ basePath }}/my-recipes">Mes recettes</a>
            <a href="{{ basePath }}/messages">
                Messages
                {% if unreadMessagesCount > 0 %}
                    <span class="badge" style="background: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.8rem; vertical-align: top;">{{ unreadMessagesCount|escape }}</span>
                {% endif %}
            </a>
            <a href="{{ basePath }}/recipes/create">Créer une recette</a>
            {% if isAdmin %}
                <a href="{{ basePath }}/admin">Administration</a>
            {% endif %}
            <a href="{{ basePath }}/logout">Déconnexion</a>
            <span class="user-badge">{{ currentUser|escape }}</span>
        {% else %}
            <a href="{{ basePath }}/signin">Connexion</a>
            <a href="{{ basePath }}/signup">Inscription</a>
        {% endif %}
    </nav>
</header>

<main class="legal-page" id="mentions-legales">

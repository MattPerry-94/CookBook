    <nav class="legal-toc" aria-label="Sommaire Mentions légales">
        <a href="#editeur">Éditeur</a>
        <a href="#conditions-utilisation">Conditions</a>
        <a href="#confidentialite">Confidentialité</a>
        <a href="#cookies">Cookies</a>
        <a href="#propriete-intellectuelle">Propriété</a>
        <a href="#responsabilite">Responsabilité</a>
    </nav>
</main>

<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="{{ basePath }}/mentions-legales" class="active">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

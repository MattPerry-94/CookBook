<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ recipe.title|escape }} - CookBook</title>
    <link rel="stylesheet" href="{{ basePath }}/public/css/style.css?v=6">
    <link rel="icon" href="{{ basePath }}/public/assets/flaticon.png" type="image/png">
</head>
<body>
<button type="button" class="nav-back-button" data-nav-back aria-label="Retour" title="Retour">←</button>
<script>
(function () {
    var btn = document.querySelector('[data-nav-back]');
    if (!btn) { return; }
    if (window.history.length <= 1) {
        btn.style.display = 'none';
        return;
    }
    btn.addEventListener('click', function () {
        window.history.back();
    });
})();
</script>
<header>
    <div>
        <strong><a class="site-brand-link" href="{{ basePath }}/" style="color: inherit; text-decoration: none;">CookBook</a></strong>
    </div>
    <nav>
        <a href="{{ basePath }}/">Accueil</a>
        {% if currentUser %}
            <a href="{{ basePath }}/my-recipes">Mes recettes</a>
            <a href="{{ basePath }}/messages">
                Messages
                {% if unreadMessagesCount > 0 %}
                    <span class="badge" style="background: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.8rem; vertical-align: top;">{{ unreadMessagesCount|escape }}</span>
                {% endif %}
            </a>
            <a href="{{ basePath }}/recipes/create">Créer une recette</a>
            {% if isAdmin %}
                <a href="{{ basePath }}/admin">Administration</a>
            {% endif %}
            <a href="{{ basePath }}/logout">Déconnexion</a>
            <span class="user-badge">{{ currentUser|escape }}</span>
        {% else %}
            <a href="{{ basePath }}/signin">Connexion</a>
        {% endif %}
    </nav>
</header>

<main class="recipe-show">
    {% if recipe.image_path %}
        <img src="{{ recipe.image_path|escape }}" alt="Photo de {{ recipe.title|escape }}" class="hero-img">
    {% endif %}
    <div class="content">
        <h1>{{ recipe.title|escape }}</h1>
        <div class="meta">
            {% if recipe.category_name %}
                <span>{{ recipe.category_name|escape }} • </span>
            {% endif %}
            {% if recipe.author_name %}
                <span>par {{ recipe.author_name|escape }}</span>
            {% endif %}
        </div>

        {% if recipe.description %}
            <p>{{ recipe.description|escape }}</p>
        {% endif %}

        <h2>Ingrédients</h2>
        {% if recipe.ingredients %}
            <ul class="ingredients-list">
                {% for line in recipe.ingredients|split('\n') %}
                    {% if line|trim is not empty %}
                        <li>{{ line|trim|escape }}</li>
                    {% endif %}
                {% endfor %}
            </ul>
        {% else %}
            <p>Aucun ingrédient renseigné.</p>
        {% endif %}

        <h2>Étapes</h2>
        {% if recipe.steps %}
            <ol class="steps-list">
                {% for line in recipe.steps|split('\n') %}
                    {% if line|trim is not empty %}
                        <li>{{ line|trim|escape }}</li>
                    {% endif %}
                {% endfor %}
            </ol>
        {% else %}
            <p>Aucune étape renseignée.</p>
        {% endif %}

        <hr style="margin: 2rem 0; border: none; border-top: 1px solid #eee;">

        <section class="comments">
            <h2>Commentaires ({{ comments|length|escape }})</h2>

            {% if currentUser %}
                <form action="{{ basePath }}/recipes/{{ recipe.id }}/comment" method="post" class="comment-form">
                    <div style="margin-bottom: 1rem;">
                        <textarea name="content" placeholder="Ajouter un commentaire..." required style="width: 100%; min-height: 80px; padding: 0.5rem;"></textarea>
                    </div>
                    <button type="submit">Publier</button>
                </form>
            {% else %}
                <p>
                    <a href="{{ basePath }}/signin">Connectez-vous</a> pour ajouter un commentaire.
                </p>
            {% endif %}

            <div class="comments-list" style="margin-top: 2rem;">
                {% for comment in comments %}
                    <div class="comment" style="background: #f9f9f9; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
                        <div class="comment-header" style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.9rem; color: #666;">
                            <div>
                                <strong>{{ comment.author_name|escape }}</strong>
                                <span> • {{ comment.created_at|date('d/m/Y H:i') }}</span>
                            </div>
                            {% if isAdmin %}
                                <form action="{{ basePath }}/admin/comments/{{ comment.id }}/delete" method="post" style="display:inline;" onsubmit="return confirm('Supprimer ce commentaire ?');">
                                    <button type="submit" style="background: none; border: none; color: red; cursor: pointer; padding: 0; font-size: 0.9rem;">Supprimer</button>
                                </form>
                            {% endif %}
                        </div>
                        <div class="comment-body">
                            {{ comment.content|escape|nl2br }}
                        </div>
                    </div>
                {% else %}
                    <p style="color: #666;">Aucun commentaire pour l'instant.</p>
                {% endfor %}
            </div>
        </section>
    </div>
</main>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="{{ basePath }}/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

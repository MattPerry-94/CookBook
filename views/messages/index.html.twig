<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes Messages - CookBook</title>
    <link rel="stylesheet" href="{{ basePath }}/public/css/style.css?v=6">
    <link rel="icon" href="{{ basePath }}/public/assets/flaticon.png" type="image/png">
</head>
<body>
<button type="button" class="nav-back-button" data-nav-back aria-label="Retour" title="Retour">←</button>
<script>
(function () {
    var btn = document.querySelector('[data-nav-back]');
    if (!btn) { return; }
    if (window.history.length <= 1) {
        btn.style.display = 'none';
        return;
    }
    btn.addEventListener('click', function () {
        window.history.back();
    });
})();
</script>
<header>
    <div>
        <strong><a class="site-brand-link" href="{{ basePath }}/" style="color: inherit; text-decoration: none;">CookBook</a></strong>
    </div>
    <nav>
        <a href="{{ basePath }}/">Accueil</a>
        {% if currentUser %}
            <a href="{{ basePath }}/my-recipes">Mes recettes</a>
            <a href="{{ basePath }}/messages" class="active">
                Messages
                {% if unreadMessagesCount > 0 %}
                    <span class="badge" style="background: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.8rem; vertical-align: top;">{{ unreadMessagesCount|escape }}</span>
                {% endif %}
            </a>
            <a href="{{ basePath }}/recipes/create">Créer une recette</a>
            {% if isAdmin %}
                <a href="{{ basePath }}/admin">Administration</a>
            {% endif %}
            <a href="{{ basePath }}/logout">Déconnexion</a>
            <span class="user-badge">{{ currentUser|escape }}</span>
        {% else %}
            <a href="{{ basePath }}/signin">Connexion</a>
        {% endif %}
    </nav>
</header>

<main class="messages-page">
    <div class="top-actions" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <h1>Mes conversations</h1>
        <a href="{{ basePath }}/messages/new" style="background: #ff7043; color: white; padding: 0.5rem 1rem; border-radius: 4px; text-decoration: none;">+ Nouveau message</a>
    </div>

    {% if conversations is defined and conversations|length > 0 %}
        <div class="conversations-list">
            {% for conv in conversations %}
                <div style="position: relative;">
                    <a href="{{ basePath }}/messages/{{ conv.contact_id }}" class="card conversation-item" style="text-decoration: none; color: inherit; display: block; padding: 1rem; margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; padding-right: 40px;">
                            <h3 style="margin: 0;">{{ conv.contact_name|default(conv.contact_email)|escape }}</h3>
                            <small style="color: #666;">{{ conv.created_at|date('d/m/Y H:i') }}</small>
                        </div>
                        <p style="margin: 0.5rem 0 0; color: #555; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 40px;">
                            {% if conv.sender_id == currentUserId %}
                                <em>Vous :</em>
                            {% endif %}
                            {{ conv.content|escape }}
                        </p>
                    </a>
                    <form action="{{ basePath }}/messages/{{ conv.contact_id }}/delete" method="post" onsubmit="return confirm('Supprimer cette conversation ?');" style="position: absolute; top: 1rem; right: 1rem;">
                        <button type="submit" style="background: #ff6b6b; color: white; border: none; width: 30px; height: 30px; border-radius: 50%; cursor: pointer; font-weight: bold; line-height: 1;">×</button>
                    </form>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p>Vous n'avez pas encore de messages.</p>
    {% endif %}
</main>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="{{ basePath }}/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

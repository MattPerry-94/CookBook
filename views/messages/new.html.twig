<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nouvelle conversation - CookBook</title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<button type="button" class="nav-back-button" data-nav-back aria-label="Retour" title="Retour">←</button>
<script>
(function () {
    var btn = document.querySelector('[data-nav-back]');
    if (!btn) { return; }
    if (window.history.length <= 1) {
        btn.style.display = 'none';
        return;
    }
    btn.addEventListener('click', function () {
        window.history.back();
    });
})();
</script>
<header>
    <div>
        <strong>CookBook</strong>
    </div>
    <nav>
        <a href="/">Accueil</a>
        {% if currentUser %}
            <a href="/my-recipes">Mes recettes</a>
            <a href="/messages" class="active">
                Messages
                {% if unreadMessagesCount > 0 %}
                    <span class="badge" style="background: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.8rem; vertical-align: top;">{{ unreadMessagesCount|escape }}</span>
                {% endif %}
            </a>
            <a href="/recipes/create">Créer une recette</a>
            {% if isAdmin %}
                <a href="/admin">Administration</a>
            {% endif %}
            <a href="/logout">Déconnexion</a>
            <span class="user-badge">{{ currentUser|escape }}</span>
        {% else %}
            <a href="/signin">Connexion</a>
        {% endif %}
    </nav>
</header>

<main>
    <div style="margin-bottom: 1rem;">
        <a href="/messages">&larr; Retour aux conversations</a>
    </div>

    <h1>Démarrer une conversation</h1>
    <p>Choisissez un utilisateur pour lui envoyer un message :</p>

    {% if users is defined and users|length > 0 %}
        <div class="users-list" style="display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));">
            {% for user in users %}
                <div class="card" style="padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem;">
                    <h3>{{ user.name|default('Utilisateur sans nom')|escape }}</h3>
                    <small>{{ user.email|escape }}</small>
                    <a href="/messages/{{ user.id }}" class="button" style="text-align: center; background: #ff7043; color: white; padding: 0.5rem; border-radius: 4px; text-decoration: none; margin-top: auto;">Envoyer un message</a>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p>Aucun autre utilisateur trouvé.</p>
    {% endif %}
</main>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

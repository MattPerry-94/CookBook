<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conversation avec {{ otherUser.name|default(otherUser.email)|escape }} - CookBook</title>
    <link rel="stylesheet" href="{{ basePath }}/public/css/style.css?v=6">
    <link rel="icon" href="{{ basePath }}/public/assets/flaticon.png" type="image/png">
    <style>
        .chat-container {
            display: flex;
            flex-direction: column;
            height: 60vh;
            border: 1px solid #ddd;
            border-radius: 8px;
            background: white;
            margin-bottom: 1rem;
        }
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .message {
            max-width: 70%;
            padding: 0.8rem;
            border-radius: 12px;
            position: relative;
        }
        .message.sent {
            align-self: flex-end;
            background: #ff7043;
            color: white;
            border-bottom-right-radius: 2px;
        }
        .message.received {
            align-self: flex-start;
            background: #f1f1f1;
            color: #333;
            border-bottom-left-radius: 2px;
        }
        .message-meta {
            font-size: 0.75rem;
            margin-top: 0.3rem;
            opacity: 0.8;
            text-align: right;
        }
        .chat-form {
            padding: 1rem;
            border-top: 1px solid #ddd;
            display: flex;
            gap: 0.5rem;
        }
        .chat-form input {
            flex: 1;
            padding: 0.8rem;
            border: 1px solid #ccc;
            border-radius: 20px;
        }
        .chat-form button {
            padding: 0 1.5rem;
            border-radius: 20px;
        }
    </style>
</head>
<body>
<button type="button" class="nav-back-button" data-nav-back aria-label="Retour" title="Retour">←</button>
<script>
(function () {
    var btn = document.querySelector('[data-nav-back]');
    if (!btn) { return; }
    if (window.history.length <= 1) {
        btn.style.display = 'none';
        return;
    }
    btn.addEventListener('click', function () {
        window.history.back();
    });
})();
</script>
<header>
    <div>
        <strong><a class="site-brand-link" href="{{ basePath }}/" style="color: inherit; text-decoration: none;">CookBook</a></strong>
    </div>
    <nav>
        <a href="{{ basePath }}/">Accueil</a>
        {% if currentUser %}
            <a href="{{ basePath }}/my-recipes">Mes recettes</a>
            <a href="{{ basePath }}/messages" class="active">
                Messages
                {% if unreadMessagesCount > 0 %}
                    <span class="badge" style="background: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.8rem; vertical-align: top;">{{ unreadMessagesCount|escape }}</span>
                {% endif %}
            </a>
            <a href="{{ basePath }}/recipes/create">Créer une recette</a>
            {% if isAdmin %}
                <a href="{{ basePath }}/admin">Administration</a>
            {% endif %}
            <a href="{{ basePath }}/logout">Déconnexion</a>
            <span class="user-badge">{{ currentUser|escape }}</span>
        {% else %}
            <a href="{{ basePath }}/signin">Connexion</a>
        {% endif %}
    </nav>
</header>

<main>
    <div style="margin-bottom: 1rem;">
        <a href="{{ basePath }}/messages">&larr; Retour aux conversations</a>
    </div>

    <h1>Conversation avec {{ otherUser.name|default(otherUser.email)|escape }}</h1>

    <div class="chat-container">
        <div class="chat-messages" id="chatMessages">
            {% for message in messages %}
                <div class="message {% if message.sender_id == currentUserId %}sent{% else %}received{% endif %}">
                    <div style="font-size: 0.8rem; font-weight: bold; margin-bottom: 0.2rem; opacity: 0.8;">
                        {% if message.sender_id == currentUserId %}
                            Moi
                        {% else %}
                            {{ message.sender_name|escape }}
                        {% endif %}
                    </div>
                    {{ message.content|escape }}
                    <div class="message-meta">{{ message.created_at|date('H:i') }}</div>
                </div>
            {% else %}
                <p style="text-align: center; color: #999; margin-top: 2rem;">Début de la conversation.</p>
            {% endfor %}
        </div>
        <form class="chat-form" method="post" action="{{ basePath }}/messages/{{ otherUser.id }}">
            <input type="text" name="content" placeholder="Écrivez votre message..." required autocomplete="off" autofocus>
            <button type="submit">Envoyer</button>
        </form>
    </div>
</main>

<script>
    // Scroll automatique vers le bas
    const chatContainer = document.getElementById('chatMessages');
    chatContainer.scrollTop = chatContainer.scrollHeight;
</script>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="{{ basePath }}/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

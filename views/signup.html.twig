<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription - CookBook</title>
    <link rel="stylesheet" href="/public/css/style.css?v=4">
</head>
<body>
<button type="button" class="nav-back-button" data-nav-back aria-label="Retour" title="Retour">←</button>
<script>
(function () {
    var btn = document.querySelector('[data-nav-back]');
    if (!btn) { return; }
    if (window.history.length <= 1) {
        btn.style.display = 'none';
        return;
    }
    btn.addEventListener('click', function () {
        window.history.back();
    });
})();
</script>
<div class="auth-page">
    <div class="auth-card">
        <h1>Inscription</h1>
        <p class="auth-subtitle">Créez votre compte pour gérer vos recettes.</p>

        {% if error is defined %}
            <div class="error" style="color: red; margin-bottom: 1rem;">{{ error|escape }}</div>
        {% endif %}

        <form method="POST" action="/signup">
            <div>
                <label for="username">Nom d'utilisateur</label>
                <input placeholder="Votre pseudo" type="text" id="username" name="username" value="{{ old_username|default('')|escape }}" required />
            </div>

            <div>
                <label for="email">Votre email</label>
                <input placeholder="nom@fournisseur.ext" type="email" id="email" name="email" value="{{ old_email|default('')|escape }}" required />
            </div>

            <div>
                <label for="password">Votre mot de passe</label>
                <input placeholder="votre mot de passe" type="password" id="password" name="password" required />
            </div>

            <div class="auth-actions">
                <button type="submit">S'inscrire</button>
                <p class="auth-link">
                    Vous avez déjà un compte ?
                    <a href="/signin">Connectez-vous</a>
                </p>
            </div>
        </form>
    </div>
</div>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

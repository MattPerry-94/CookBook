<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestion des recettes - CookBook</title>
    <link rel="stylesheet" href="/public/css/style.css?v=6">
    <link rel="icon" href="/public/assets/flaticon.png" type="image/png">
</head>
<body>
<button type="button" class="nav-back-button" data-nav-back aria-label="Retour" title="Retour">←</button>
<script>
(function () {
    var btn = document.querySelector('[data-nav-back]');
    if (!btn) { return; }
    if (window.history.length <= 1) {
        btn.style.display = 'none';
        return;
    }
    btn.addEventListener('click', function () {
        window.history.back();
    });
})();
</script>
<header>
    <div>
        <strong><a class="site-brand-link" href="/" style="color: inherit; text-decoration: none;">CookBook - Admin</a></strong>
    </div>
    <nav>
        <a href="/admin">Utilisateurs</a>
        <a href="/">Accueil</a>
        <a href="/messages">
            Messages
            {% if unreadMessagesCount > 0 %}
                <span class="badge" style="background: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.8rem; vertical-align: top;">{{ unreadMessagesCount }}</span>
            {% endif %}
        </a>
        {% if isAdmin %}
            <a href="/admin">Administration</a>
        {% endif %}
        <a href="/logout">Déconnexion</a>
        {% if currentUser %}
            <span class="user-badge">{{ currentUser|escape }}</span>
        {% endif %}
    </nav>
</header>

<main class="recipes-my">
    <div class="top-actions">
        <h1>Gestion des recettes</h1>
    </div>

    {% if recipes is defined and recipes|length > 0 %}
        <table>
            <thead>
            <tr>
                <th>ID</th>
                <th>Titre</th>
                <th>Auteur</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for recipe in recipes %}
                <tr>
                    <td>{{ recipe.id |escape }}</td>
                    <td>{{ recipe.title|escape }}</td>
                    <td>
                        {{ recipe.author_name|default('')|escape }}<br>
                        <small>{{ recipe.author_email|escape }}</small>
                    </td>
                    <td>{{ recipe.created_at|date('d/m/Y H:i') }}</td>
                    <td class="actions">
                        <a href="/recipes/{{ recipe.id }}">Voir</a>
                        <form method="post"
                              action="/admin/recipes/{{ recipe.id }}/delete"
                              style="display:inline"
                              onsubmit="return confirm('Supprimer cette recette ?');">
                            <button type="submit" class="btn-link">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>Aucune recette trouvée.</p>
    {% endif %}
</main>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

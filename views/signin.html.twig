<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - CookBook</title>
    <link rel="stylesheet" href="/public/css/style.css?v=6">
    <link rel="icon" href="/public/assets/flaticon.png" type="image/png">
</head>
<body>
<button type="button" class="nav-back-button" data-nav-back aria-label="Retour" title="Retour">←</button>
<script>
(function () {
    var btn = document.querySelector('[data-nav-back]');
    if (!btn) { return; }
    if (window.history.length <= 1) {
        btn.style.display = 'none';
        return;
    }
    btn.addEventListener('click', function () {
        window.history.back();
    });
})();
</script>
<div class="auth-page">
    <div class="auth-card">
        <h1>Connexion</h1>
        <p class="auth-subtitle">Connectez-vous pour gérer vos recettes.</p>

        {% if error is defined %}
            <div class="error" style="color: red; margin-bottom: 1rem;">{{ error|escape }}</div>
        {% endif %}

        <form method="POST" action="/signin">
            <div>
                <label for="mail">Votre email</label>
                <input placeholder="nom@exemple.com" id="mail" name="mail" type="email" value="{{ old_email|default('')|escape }}" required>
            </div>

            <div>
                <label for="pwd">Votre mot de passe</label>
                <input placeholder="mot de passe" id="pwd" name="pwd" type="password" required>
            </div>

            <div class="auth-actions">
                <button type="submit">Se connecter</button>
                <p class="auth-link">
                    Pas encore de compte ?
                    <a href="/signup">Inscrivez-vous</a>
                </p>
            </div>
        </form>
    </div>
</div>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modifier un utilisateur - CookBook</title>
    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<button type="button" class="nav-back-button" data-nav-back aria-label="Retour" title="Retour">←</button>
<script>
(function () {
    var btn = document.querySelector('[data-nav-back]');
    if (!btn) { return; }
    if (window.history.length <= 1) {
        btn.style.display = 'none';
        return;
    }
    btn.addEventListener('click', function () {
        window.history.back();
    });
})();
</script>
<header>
    <div>
        <strong>CookBook - Admin</strong>
    </div>
    <nav>
        <a href="/admin">Retour à la liste</a>
        <a href="/logout">Déconnexion</a>
    </nav>
</header>

<main class="recipe-form">
    <h1>Modifier l'utilisateur #{{ user.id }}</h1>

    {% if error is defined %}
        <div class="error">{{ error|escape }}</div>
    {% endif %}

    <form method="post">
        <div>
            <label for="name">Nom</label>
            <input type="text" id="name" name="name" value="{{ user.name|default('')|escape }}">
        </div>

        <div>
            <label for="email">Email *</label>
            <input type="text" id="email" name="email" value="{{ user.email|escape }}" required>
        </div>

        <div>
            <label for="role">Rôle *</label>
            <select id="role" name="role" required>
                <option value="user" {% if user.role == 'user' %}selected{% endif %}>Utilisateur</option>
                <option value="admin" {% if user.role == 'admin' %}selected{% endif %}>Administrateur</option>
            </select>
        </div>

        <div>
            <label>
                <input type="checkbox" name="active" value="1" {% if user.active is defined and user.active == 1 %}checked{% endif %}>
                Compte actif
            </label>
        </div>

        <div class="actions">
            <button type="submit">Enregistrer</button>
        </div>
    </form>
</main>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
        <div class="site-footer__brand">
            <strong>CookBook</strong>
            <span>© {{ "now"|date("Y") }} CookBook. Tous droits réservés.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Pied de page">
            <a href="/mentions-legales">Mentions légales</a>
        </nav>
    </div>
</footer>
</body>
</html>
